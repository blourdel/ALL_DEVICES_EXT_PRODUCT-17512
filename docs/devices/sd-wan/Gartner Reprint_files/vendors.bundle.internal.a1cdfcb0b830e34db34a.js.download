box-shadow: none;\n}\n.parentcontainer:focus {\n  outline: none;\n}\n.parentcontainer:focus-visible {\n  outline: none;\n}\n.parentcontainer .gartner-popover-arrow {\n  left: -15px;\n  transform: rotate(270deg);\n  width: 25px;\n  height: 25px;\n  position: absolute;\n  display: block;\n  top: 4px;\n}\n.parentcontainer .gartner-popover-arrow svg {\n  fill: #eeeeee;\n}\n.add-folder-message p {\n  padding: 0px 24px;\n  font-size: 16px;\n  font-weight: 400;\n  color: #000000;\n  line-height: 24px;\n  margin: 0;\n}\n.add-folder-message a {\n  text-decoration: none;\n  cursor: initial;\n  color: #027cb5;\n}\n.saved-wrapper__title {\n  padding: 8px 24px;\n  font-weight: 500;\n  font-size: 16px;\n  line-height: 24px;\n}\n.folderList {\n  overflow-y: auto;\n  padding: 0;\n  margin: 0;\n  height: 260px;\n  box-shadow: inset 0px -1px 0px #e6eaee;\n}\n.folder-wrapper:focus {\n  background: #eeeeee;\n  outline: 0;\n}\n.folder-wrapper:hover {\n  background: #E8E8E8;\n}\n.folder-wrapper .folder-container {\n  padding: 16px 24px;\n  font-weight: 500;\n}\n.folder-wrapper .folder-container .library-folder-link {\n  cursor: pointer;\n  text-decoration: none;\n  overflow: hidden;\n  display: flex;\n  align-items: center;\n}\n.folder-wrapper .folder-container .folder-image {\n  width: 20px;\n  height: 16px;\n  float: left;\n  vertical-align: top;\n  fill: #3E3E3E;\n}\n.folder-wrapper .folder-container .folder-name {\n  float: left;\n  font-size: 16px;\n  line-height: 24px;\n  color: #3E3E3E;\n  padding-left: 6px;\n  margin: 0;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  font-weight: 400;\n}\n.folder-wrapper .folder-container .saved-file-number {\n  font-size: 15px;\n  font-weight: 500;\n  color: #5c6970;\n  margin: 0;\n  padding-left: 16px;\n  display: inline-block;\n}\n.addnewfolderwrapper {\n  padding: 16px 32px;\n}\n.addnewfolderwrapper .title {\n  color: #002856;\n  font-size: 16px;\n  font-weight: 500;\n  margin: 0;\n  line-height: 24px;\n}\n.addnewfolderwrapper .error-mes